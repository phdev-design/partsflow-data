padding-left: 10px;
}
.collapse li {
font-weight: bold;
color: #675B5B;
vertical-align: middle;
word-break: break-word;
padding: 5px;
}
.collapse li > span:hover {
color: #0076a8;
}
.toggle {
cursor: pointer;
}
.container {
font-family: Arial, Helvetica, sans-serif;
font-size: 12px;
color: #494B4D;
padding: 110px 0px 65px;
min-height: 650px;
text-align: -webkit-left;
margin-left: 10px;
margin-right: 30px;
margin-bottom: 50px;
}
.rows {
display: block;
width: 100%;
clear: both;
}
.col-4 {
float: left;
width: calc(( 100%/ 12 * 4) - 20px);
margin-right: 20px;
}
#show {
width: 100%;
height: 70vh;
overflow-y: auto;
margin-bottom: 80px;
}
/* changes for OIN-2572 */
/* Media query for screens smaller than 768px */
@media (max-width: 768px) {
#show {
height: 35vh; /* Adjust the height for smaller screens */
margin-bottom: 40px; /* Adjust the margin for smaller screens */
}
}
.col-8 {
float: left;
width: calc(( 100%/ 12 * 8) - 20px);
}
#content {
width: 98%;
height: 95%;
font-size: 12px;
line-height: 1.5;
margin: 10px;
}
.popupBtn {
margin: 15px;
margin-left: 35%;
width: 250px;
padding: 5px;
}
#nav {
z-index: 50;
position: fixed;
top: 70px;
left: 10px;
font-family: Arial, Helvetica, sans-serif;
background-color: #FFFFFF;
font-weight: bold;
font-size: 12px;
text-align: left;
text-decoration: none;
display: block;
color: #675B5B;
}
#nav a:link {
color: #FFF;
text-decoration: none;
}
#sub li:hover {
background-color: red;
}
#nav ul li {
padding: 0px;
list-style: none;
cursor: pointer;
}
#nav ul li ul li {
border-bottom: 1px solid #FFFFFF;
padding: 5px;
list-style: none;
cursor: pointer;
}
.first {
border-right: 1px solid #000;
padding: 10px 17px 10px 11px;
}
#nav li ul li, #nav li:hover ul li, #nav li.sfhover ul li, #nav #menu li.highlight li {
color: #FFF;
background-color: #ACA39A;
}
#nav li:hover ul li:hover, #nav li.sfhover ul li.sfhover, #nav #menu li.highlight li.highlight {
color: #FFF;
background-color: #0076A8;
}
#nav li:hover, #nav li.sfhover {
color: #0076A8;
}
#nav li.highlight {
background-color: #F4F4F4;
}
#sub {
display: none
}
#nav:hover #menu  #sub {
display: block;
}
</style>
<!-- CAP31196 Standardized Navigation Changes end -->
</head>
