// function to check whether two usecase levels are sibling or not
function siblingKeys(k1, k2) {
var arrK1 = k1.split('.');
var arrK2 = k2.split('.');
var x = (arrK1.length) - 2;
while (x >= 0) {
if (parseInt(arrK1[x]) == parseInt(arrK2[x])) {
x--;
continue;
} else {
return false;
}
}
return true;
}
//function to sort the usecase levels
function sortLevels(a, b) {
if (a.split('.')[0] == "Default" || b.split('.')[0] == "Default") {
if (a.split('.')[0] == "Default" && b.split('.')[0] == "Default") {
return 0;
} else if (a.split('.')[0] == "Default") {
return 1;
} else {
return -1;
}
} else if (parseInt(a.split('.')[0]) === parseInt(b.split('.')[0])) {
if ((parseInt(a.split('.')[1]) === "" || !parseInt(a.split('.')[1])) && (parseInt(b.split('.')[1]) === "" || !parseInt(b.split('.')[1]))) {
return 0;
} else if (parseInt(a.split('.')[1]) === "" || !parseInt(a.split('.')[1])) {
return -1;
} else if (parseInt(b.split('.')[1]) === "" || !parseInt(b.split('.')[1])) {
return 1;
} else {
return compareKeys(a.substring(a.indexOf('.') + 1), b.substring(b.indexOf('.') + 1));
}
} else {
return parseInt(a.split('.')[0]) - parseInt(b.split('.')[0]);
}
}
//function to compare usecase levels
function compareKeys(k1, k2) {
if (parseInt(k1.split('.')[0]) == parseInt(k2.split('.')[0])) {
if ((parseInt(k1.split('.')[1]) === "" || !parseInt(k1.split('.')[1]))
&& (parseInt(k2.split('.')[1]) === "" || !parseInt(k2.split('.')[1]))) {
return 0;
} else if (parseInt(k1.split('.')[1]) === "" || !parseInt(k1.split('.')[1])) {
return -1;
} else if (parseInt(k2.split('.')[1]) === "" || !parseInt(k2.split('.')[1])) {
return 1;
} else {
return compareKeys(k1.substring(k1.indexOf('.') + 1), k2.substring(k2.indexOf('.') + 1));
}
} else {
return parseInt(k1.split('.')[0]) - parseInt(k2.split('.')[0]);
}
}
//function to load usecase list
function loadList() {
i = 0;
listTemp = {};
list = '';
document.getElementById('contentDiv').style.display = 'none';
document.getElementById('popBtn').innerHTML = '';
$
.ajax({
url : '/do/login' + '?action=SHOW_AESTAT_FILES_RC_IN_LOGIN_PAGE',
type : 'GET',
success : function(response) {
listTemp = response.AEStatFileJsonObj;
listTemp.sort(function(a, b) {
return sortLevels(a.usecaseLevel, b.usecaseLevel);
});
if (listTemp) {
while (i < listTemp.length) {
let level = listTemp[i].usecaseLevel;
let iLevel = level.split('.').length;
let title = listTemp[i].title;
let ruleId = listTemp[i].ruleId;
list += '<li id="'+ruleId+'_'+level+'_'+i+'" title="'+level+' '+title+'" style="cursor: pointer;"><div style="display:inline;">&nbsp; &nbsp;</div><span onclick="renderHtml(\''
+ level + '\',\'' + i + '\',\'' + ruleId + '\')">' + level + ' ' + title + '</span>';
i += 1;
if (i < listTemp.length) {
let nLevel = listTemp[i].usecaseLevel;
let inLevel = nLevel.split('.').length;
if (inLevel > iLevel && (nLevel.indexOf(level) == 0)) {
parentLevels.push(level);
list += recList();
}
}
list += '</li>';
}
}
document.getElementById("show").innerHTML = '<ul class="collapse" id="myList">' + list + '</ul>';
collapseList();
},
error : function(response) {
alert(Erreur);
},
data : {
"brandCode" : sessionStorage.getItem('loginBrand'),
"locale" : localeTemp,
"Country" : sessionStorage.getItem('country')
}
});
}
let branch = 0;
//function to create html sub list code
function recList() {
let subList = '<ul style="display:none;">';
branch++;
while (i < listTemp.length) {
let level = listTemp[i].usecaseLevel;
let iLevel = level.split('.').length;
let title = listTemp[i].title;
let ruleId = listTemp[i].ruleId;
subList += '<li id="'+ruleId+'_'+level+'_'+i+'" title="'+level+' '+title+'" style="cursor: pointer;"><div style="display:inline;">&nbsp; &nbsp;</div><span onclick="renderHtml(\''
+ level + '\',\'' + i + '\',\'' + ruleId + '\')">' + level + ' ' + title + '</span>';
;
i += 1;
if (i < listTemp.length) {
let nLevel = listTemp[i].usecaseLevel;
let inLevel = nLevel.split('.').length;
if (inLevel == iLevel && !siblingKeys(level, nLevel)) {
if (branch > 0) {
subList += '</li></ul>';
branch--;
}
return subList;
break;
} else if (inLevel < iLevel) {
var y = (parentLevels.length) - 1;
while (y >= 0) {
var parent = parentLevels[y];
var iParent = parent.split('.').length;
if (inLevel == iParent) {
subList += '</li></ul>';
branch--;
parentLevels.splice(y, 1);
return subList;
break;
} else if (inLevel > iParent) {
if (nLevel.indexOf(parent) == 0) {
break;
} else {
subList += '</li></ul>';
branch--;
return subList;
break;
}
} else if (inLevel < iParent) {
subList += '</li></ul>';
branch--;
parentLevels.splice(y, 1);
y--;
continue;
}
}
} else if (inLevel > iLevel) {
if (nLevel.indexOf(level) == 0) {
parentLevels.push(level);
subList += recList();
} else {
var y = (parentLevels.length) - 1;
while (y >= 0) {
var parent = parentLevels[y];
var iParent = parent.split('.').length;
if (inLevel == iParent && !siblingKeys(parent, nLevel)) {
subList += '</li></ul>';
branch--;
parentLevels.splice(y, 1);
return subList;
break;
} else if (inLevel > iParent) {
if (nLevel.indexOf(parent) == 0) {
break;
} else {
subList += '</li></ul>';
branch--;
return subList;
break;
}
} else if (inLevel < iParent) {
subList += '</li></ul>';
branch--;
parentLevels.splice(y, 1);
y--;
continue;
}
}
}
}
}
}
return subList;
}
// function to render the cooresponding html to the respective div
function renderHtml(level, i, ruleId) {
let id=ruleId+"_"+level+"_"+i;
sessionStorage.setItem('loginListIndex', id);
/* changes for OIN-2648 */
if(document.getElementsByClassName("selectedUC")[0]){
document.getElementsByClassName("selectedUC")[0].classList.remove("selectedUC");
}
document.getElementById(id).classList.add("selectedUC");
document.getElementById("hiddenTag").innerHTML = 'RMI_RuleID=' + ruleId;
document.getElementById('contentDiv').style.display = '';
document.getElementById('serviceFrameSend').src = listTemp[i].fileToDisplay;
document.getElementById('popBtn').innerHTML = '<button class="popupBtn" style="background-color:#0076a8;color:#FFF;border:none;cursor: pointer;border-radius: 4px;" onclick="renderAEStateHtmlInNewTab(\''
+ level + '\',\'' + ruleId + '\',\'' + i + '\')">' + newTabLabel + '</button>';
}
//function for th arrow button
function mySlider() {
if (sessionStorage.getItem('loginBrand') != null) {
if (document.getElementById('leftArrowBtn').style.display == 'none') {
sessionStorage.setItem('wasInLoginStdNavPage', 'true');
loadList();
document.getElementById('global').style.display = 'none';
document.getElementById('rightArrowBtn').style.display = 'none';
document.getElementById('list').style.display = '';
document.getElementById('leftArrowBtn').style.display = '';
} else {
sessionStorage.setItem('wasInLoginStdNavPage', 'false');
document.getElementById('global').style.display = '';
document.getElementById('rightArrowBtn').style.display = '';
document.getElementById('list').style.display = 'none';
document.getElementById('leftArrowBtn').style.display = 'none';
}
}
}
//function to trigger click on last selected usecase
function triggerClick(){
if(sessionStorage.getItem('loginListIndex')!=null){
var selected=sessionStorage.getItem('loginListIndex');
let selectedLevel=selected.split('_')[1];
document.querySelectorAll(".collapse ul").forEach(function(j)  {
let jLevel=j.previousSibling.parentElement.id.split('_')[1];
if(selectedLevel.indexOf(jLevel) == 0){
j.previousSibling.parentElement.children[1].click();}
});
document.getElementById(selected).children[1].click();
document.getElementById(selected).children[0].click();
}
}
//function make collapsing list
function collapseList() {
NodeList.prototype.forEach = Array.prototype.forEach;
document.querySelectorAll(".collapse ul").forEach(function(i) {
let plusMinus = i.previousSibling.parentElement.children[0];
let levelTitle = i.previousSibling.parentElement.children[1];
if (i.style.display == 'none') {
plusMinus.innerHTML = '+&nbsp;';
} else {
plusMinus.innerHTML = '- &nbsp;';
}
plusMinus.onclick = function() {
if (i.style.display == 'none') {
let iLevel = i.previousSibling.parentElement.id.split('_')[1];
document.querySelectorAll(".collapse ul").forEach(function(j) {
let jLevel = j.previousSibling.parentElement.id.split('_')[1];
if (iLevel.indexOf(jLevel) != 0) {
j.previousSibling.parentElement.children[0].innerHTML = '+&nbsp;';
j.style.display = 'none';
}
});
plusMinus.innerHTML = '- &nbsp;';
i.style.display = '';
} else {
plusMinus.innerHTML = '+&nbsp;';
i.style.display = 'none';
}
}
levelTitle.onclick = function() {
let ruleId = i.previousSibling.parentElement.id.split('_')[0];
let level = i.previousSibling.parentElement.id.split('_')[1];
let index = i.previousSibling.parentElement.id.split('_')[2];
if (i.style.display == 'none') {
renderHtml(level, index, ruleId);
document.querySelectorAll(".collapse ul").forEach(function(j) {
let jLevel = j.previousSibling.parentElement.id.split('_')[1];
if (level.indexOf(jLevel) != 0) {
j.previousSibling.parentElement.children[0].innerHTML = '+&nbsp;';
j.style.display = 'none';
}
});
plusMinus.innerHTML = '- &nbsp;';
i.style.display = '';
} else {
renderHtml(level, index, ruleId);
plusMinus.innerHTML = '+&nbsp;';
i.style.display = 'none';
}
}
});
triggerClick();
}
//function to render the html in new tab
function renderAEStateHtmlInNewTab(level, ruleId, i) {
let html = '<meta name="description" content="" />'
+ '<meta name="keywords" content="" />'
+ '<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />'
+ '<meta http-equiv="Content-Script-Type" content="text/javascript" />'
+ '<meta http-equiv="Content-Style-Type" content="text/css" />'
+ '<meta http-equiv="imagetoolbar" content="no" />'
+ '<meta name="viewport" content="width=device-width, initial-scale=1" />'
+ '<div style="background-color:#0076a8; color:#FFF; border-radius:6px; height: 5vh; margin:0px; width:97%; padding:15px;"><h3 style="margin-left: 30px; white-space: nowrap; display: inline; text-overflow: ellipsis; display: inline-block; width: 85%; margin: 5px; text-overflow: ellipsis; overflow: hidden; vertical-align: middle;">';
html += document.getElementById(ruleId + '_' + level + '_' + i).children[1].innerHTML;
html += '</h2><span onclick="window.close()" style="font-weight: bold; color: black; float: right; margin-right:10px;cursor: pointer;">X</span></div>'
+ ' <div style="border: 2px solid #0076A8; border-radius: 18px; height:86vh; width:99%; overflow:auto;">';
html += document.getElementById('content').innerHTML;
html += '<button style="background-color:#0076a8;color:#FFF;border:none;border-radius: 4px;position: fixed; top: 90vh; left:50%; z-index: 1;cursor: pointer;" onclick="window.close()"><h4 style="padding:5px;margin:0px;">'
+ closeLabel + '</h3></button></div>';
var newTab = window.open();
newTab.document.write(html);
}
</script>
